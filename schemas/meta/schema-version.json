{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roborean.dev/schemas/meta/schema-version.json",
  "type": "object",
  "required": ["schemaVersion"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Roborean project format version (semver)."
    }
  },
  "additionalProperties": true
}
