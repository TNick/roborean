{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roborean.dev/schemas/recipe.schema.json",
  "title": "BitRecipe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "name",
    "requiredBitTypes",
    "pluginRequirements",
    "workspace",
    "documents",
    "templates",
    "bits",
    "insertPolicy"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["1.0.0"] },
    "kind": { "const": "bit-recipe" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredBitTypes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["typeId", "versionRange"],
        "properties": {
          "typeId": { "type": "string", "minLength": 1 },
          "versionRange": { "type": "string", "minLength": 1 }
        }
      }
    },
    "requiredDocumentDrivers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pluginRequirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "versionRange"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "versionRange": { "type": "string", "minLength": 1 }
        }
      }
    },
    "workspace": { "$ref": "workspace.schema.json" },
    "documents": {
      "type": "array",
      "items": { "$ref": "document-definition.schema.json" }
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "hash": { "type": "string" }
        }
      }
    },
    "templateContents": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "bits": {
      "type": "array",
      "items": { "$ref": "bit.schema.json" }
    },
    "insertPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bitPlacement",
        "onVariableConflict",
        "onDocumentConflict",
        "onBitIdConflict"
      ],
      "properties": {
        "bitPlacement": { "type": "string", "enum": ["append"] },
        "onVariableConflict": {
          "type": "string",
          "enum": ["keep-existing", "rename"]
        },
        "onDocumentConflict": {
          "type": "string",
          "enum": ["keep-existing", "remap"]
        },
        "onBitIdConflict": { "type": "string", "enum": ["rename"] }
      }
    }
  }
}
