{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roborean.dev/schemas/document-preview.schema.json",
  "title": "DocumentPreview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "documentId",
    "mode",
    "body",
    "warnings",
    "generatedAt",
    "renderer"
  ],
  "properties": {
    "documentId": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["text", "html", "drawing-json"]
    },
    "body": {},
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "renderer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "version"],
      "properties": {
        "package": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  }
}
