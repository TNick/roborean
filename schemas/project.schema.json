{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roborean.dev/schemas/project.schema.json",
  "title": "Project",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "pluginRequirements",
    "workspace",
    "bits",
    "documents",
    "templates",
    "metadata"
  ],
  "properties": {
    "schemaVersion": {"enum": ["1.0.0", "1.1.0"]},
    "id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "pluginRequirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "versionRange"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "versionRange": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "workspace": {"$ref": "workspace.schema.json"},
    "bits": {"type": "array", "items": {"$ref": "bit.schema.json"}},
    "documents": {
      "type": "array",
      "items": {"$ref": "document-definition.schema.json"}
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "hash": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "metadata": {"type": "object"}
  },
  "additionalProperties": false
}
