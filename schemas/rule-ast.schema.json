{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roborean.dev/schemas/rule-ast.schema.json",
  "title": "RuleAst",
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["op", "args"],
      "properties": {
        "op": {
          "enum": [
            "and",
            "or",
            "not",
            "eq",
            "ne",
            "lt",
            "le",
            "gt",
            "ge",
            "has",
            "const",
            "var"
          ]
        },
        "args": {"type": "array"}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"op": {"const": "const"}}},
          "then": {
            "properties": {
              "args": {
                "type": "array",
                "minItems": 1,
                "maxItems": 1,
                "items": {"type": ["string", "number", "boolean", "null"]}
              }
            }
          }
        },
        {
          "if": {"properties": {"op": {"const": "var"}}},
          "then": {
            "properties": {
              "args": {
                "type": "array",
                "prefixItems": [{"type": "string"}],
                "items": false
              }
            }
          }
        },
        {
          "if": {"properties": {"op": {"const": "has"}}},
          "then": {
            "properties": {
              "args": {
                "type": "array",
                "prefixItems": [{"$ref": "#/$defs/ruleOrKey"}],
                "items": false
              }
            }
          }
        },
        {
          "if": {"properties": {"op": {"const": "not"}}},
          "then": {
            "properties": {
              "args": {
                "type": "array",
                "prefixItems": [{"$ref": "#/$defs/rule"}],
                "items": false
              }
            }
          }
        },
        {
          "if": {"properties": {"op": {"enum": ["and", "or"]}}},
          "then": {
            "properties": {
              "args": {
                "type": "array",
                "items": {"$ref": "#/$defs/rule"}
              }
            }
          }
        },
        {
          "if": {"properties": {"op": {"enum": ["eq", "ne", "lt", "le", "gt", "ge"]}}},
          "then": {
            "properties": {
              "args": {
                "type": "array",
                "prefixItems": [
                  {"$ref": "#/$defs/rule"},
                  {"$ref": "#/$defs/rule"}
                ],
                "items": false
              }
            }
          }
        }
      ]
    },
    "ruleOrKey": {
      "oneOf": [{"type": "string"}, {"$ref": "#/$defs/rule"}]
    }
  },
  "$ref": "#/$defs/rule"
}
