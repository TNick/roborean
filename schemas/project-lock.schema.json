{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roborean.dev/schemas/project-lock.schema.json",
  "title": "ProjectLock",
  "type": "object",
  "additionalProperties": false,
  "required": ["lockVersion", "bitTypes"],
  "properties": {
    "lockVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "bitTypes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
      }
    },
    "documentDrivers": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
      }
    }
  }
}
