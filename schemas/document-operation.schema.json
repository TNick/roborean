{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roborean.dev/schemas/document-operation.schema.json",
  "title": "DocumentOperation",
  "type": "object",
  "required": ["documentId", "op"],
  "properties": {
    "documentId": { "type": "string", "minLength": 1 },
    "op": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": { "properties": { "op": { "const": "set_metadata" } } },
      "then": {
        "required": ["key", "value"],
        "properties": {
          "documentId": true,
          "op": true,
          "key": { "type": "string" },
          "value": true
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "replace_named_value" } } },
      "then": {
        "required": ["name", "value"],
        "properties": {
          "documentId": true,
          "op": true,
          "name": { "type": "string" },
          "value": { "$ref": "workspace-value.schema.json" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "finalize" } } },
      "then": {
        "properties": {
          "documentId": true,
          "op": true,
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "plain.append_text" } } },
      "then": {
        "required": ["text"],
        "properties": {
          "documentId": true,
          "op": true,
          "text": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "plain.replace_all" } } },
      "then": {
        "required": ["find", "replace"],
        "properties": {
          "documentId": true,
          "op": true,
          "find": { "type": "string" },
          "replace": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "flow.insert_paragraph" } } },
      "then": {
        "required": ["runs"],
        "properties": {
          "documentId": true,
          "op": true,
          "after": { "type": "string" },
          "runs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["text"],
              "properties": { "text": { "type": "string" } },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "flow.insert_heading" } } },
      "then": {
        "required": ["level", "text"],
        "properties": {
          "documentId": true,
          "op": true,
          "level": { "type": "integer", "minimum": 1, "maximum": 6 },
          "text": { "type": "string" },
          "after": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "flow.replace_table_rows" } } },
      "then": {
        "required": ["table", "rows"],
        "properties": {
          "documentId": true,
          "op": true,
          "table": { "type": "string" },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "sheet.set_cell" } } },
      "then": {
        "required": ["sheet", "cell", "value"],
        "properties": {
          "documentId": true,
          "op": true,
          "sheet": { "type": "string" },
          "cell": { "type": "string" },
          "value": { "$ref": "workspace-value.schema.json" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "sheet.set_formula" } } },
      "then": {
        "required": ["sheet", "cell", "formula"],
        "properties": {
          "documentId": true,
          "op": true,
          "sheet": { "type": "string" },
          "cell": { "type": "string" },
          "formula": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "sheet.ensure_sheet" } } },
      "then": {
        "required": ["name"],
        "properties": {
          "documentId": true,
          "op": true,
          "name": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "drawing.ensure_layer" } } },
      "then": {
        "required": ["name"],
        "properties": {
          "documentId": true,
          "op": true,
          "name": { "type": "string" },
          "color": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "drawing.insert_polyline" } } },
      "then": {
        "required": ["layer", "points"],
        "properties": {
          "documentId": true,
          "op": true,
          "layer": { "type": "string" },
          "points": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "drawing.insert_text" } } },
      "then": {
        "required": ["layer", "at", "text"],
        "properties": {
          "documentId": true,
          "op": true,
          "layer": { "type": "string" },
          "at": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 2
          },
          "text": { "type": "string" },
          "height": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "raster.draw_text" } } },
      "then": {
        "required": ["layer", "text", "anchor"],
        "properties": {
          "documentId": true,
          "op": true,
          "layer": { "type": "string" },
          "text": { "type": "string" },
          "anchor": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 2
          },
          "font": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "if": { "properties": { "op": { "const": "raster.set_size" } } },
      "then": {
        "required": ["width", "height"],
        "properties": {
          "documentId": true,
          "op": true,
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  ]
}
