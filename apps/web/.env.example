# Local dual mode (recommended): FastAPI + optional Google Drive.
# Leave VITE_STORAGE_MODE unset (or set api). Google folder selection is
# optional when the API is available; projects are listed from both.
# VITE_STORAGE_MODE=api
VITE_API_BASE_URL=http://localhost:8765
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Required for Google Picker (API key, often AIza… — not the OAuth secret)
# VITE_GOOGLE_API_KEY=
# Optional override for Picker setAppId (defaults to project number from client id)
# VITE_GOOGLE_APP_ID=

# Google-only (GitHub Pages / static): no API; Drive folder is required.
# VITE_STORAGE_MODE=google
