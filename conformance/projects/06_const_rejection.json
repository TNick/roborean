{
  "schemaVersion": "1.0.0",
  "id": "example.const-rejection",
  "name": "Const rejection",
  "pluginRequirements": [],
  "workspace": {
    "variables": [
      {
        "key": "title",
        "schema": { "type": "string" },
        "defaultValue": {
          "kind": "public_literal",
          "dataType": "string",
          "value": "Hello"
        },
        "const": true,
        "exposure": "clientVisible"
      }
    ]
  },
  "bits": [
    {
      "id": "set_const_title",
      "type": "roborean.set_variable",
      "when": true,
      "config": {
        "key": "title",
        "value": {
          "kind": "public_literal",
          "dataType": "string",
          "value": "World"
        }
      },
      "reads": [],
      "writes": ["title"],
      "emits": [],
      "effectClass": "workspace",
      "onError": "abort",
      "capabilities": ["workspace.write"]
    }
  ],
  "documents": [],
  "templates": [],
  "metadata": {}
}
