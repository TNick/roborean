{
  "schemaVersion": "1.0.0",
  "id": "example.secret-ref",
  "name": "Secret reference",
  "pluginRequirements": [],
  "workspace": {
    "variables": [
      {
        "key": "registry.api_token",
        "schema": { "type": "string" },
        "defaultValue": {
          "kind": "secret_ref",
          "ref": "sec:project-default:registry-api-token",
          "displayHint": "Configured registry token"
        },
        "const": false,
        "exposure": "backendOnly"
      },
      {
        "key": "registry.api_token_copy",
        "schema": { "type": "string" },
        "defaultValue": {
          "kind": "secret_ref",
          "ref": "sec:project-default:empty-token"
        },
        "const": false,
        "exposure": "backendOnly"
      }
    ]
  },
  "bits": [
    {
      "id": "copy_secret_reference",
      "type": "roborean.copy_variable",
      "when": true,
      "config": {
        "from": "registry.api_token",
        "to": "registry.api_token_copy"
      },
      "reads": ["registry.api_token"],
      "writes": ["registry.api_token_copy"],
      "emits": [],
      "effectClass": "workspace",
      "onError": "abort",
      "capabilities": ["workspace.read", "workspace.write"]
    }
  ],
  "documents": [],
  "templates": [],
  "metadata": {}
}
